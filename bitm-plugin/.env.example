# ══════════════════════════════════════════════════════════
#  BitM Detection Plugin v5 — Configurazione
#  Copia in .env e modifica i valori
#  cp .env.example .env
# ══════════════════════════════════════════════════════════

# ── Backend LLM ───────────────────────────────────────────
# Scegli tra "anthropic" (default) o "ollama"
LLM_BACKEND=ollama

# ── Opzione A: Ollama locale ──────────────────────────────
# Assicurati che Ollama sia avviato:  ollama serve
# Assicurati di avere il modello:    ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=60

# ── Opzione B: Anthropic Cloud ────────────────────────────
# (usato solo se LLM_BACKEND=anthropic)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Cache ─────────────────────────────────────────────────
# TTL in secondi per la cache dei risultati (default 300 = 5 minuti)
CACHE_TTL=300

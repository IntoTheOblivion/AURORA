
# ══════════════════════════════════════════════════════════
#  BitM Detection Plugin v6.2 — Configurazione
#  Copia in .env e modifica i valori
#  cp .env.example .env
# ══════════════════════════════════════════════════════════

# ── Backend LLM ───────────────────────────────────────────
# Scegli tra "anthropic" (default) o "ollama"
LLM_BACKEND=ollama

# ── Opzione A: Ollama locale ──────────────────────────────
# Assicurati che Ollama sia avviato:  ollama serve
# Assicurati di avere il modello:    ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=60

# ── Opzione B: Anthropic Cloud ────────────────────────────
# (usato solo se LLM_BACKEND=anthropic)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Cache ─────────────────────────────────────────────────
# TTL in secondi per la cache dei risultati (default 300 = 5 minuti)
CACHE_TTL=300

# ── Webhook push notifications (v6.2) ─────────────────────
# Decommentare e configurare per attivare le notifiche BLOCK

# Slack (Blocks API)
# WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# WEBHOOK_TYPE=slack

# Microsoft Teams (Adaptive Cards)
# WEBHOOK_URL=https://outlook.office.com/webhook/...
# WEBHOOK_TYPE=teams

# SIEM / JSON generico
# WEBHOOK_URL=https://siem.azienda.local/events
# WEBHOOK_TYPE=siem

# Parametri comuni (opzionali)
# WEBHOOK_TIMEOUT=5        # secondi per singola richiesta HTTP
# WEBHOOK_RETRIES=3        # tentativi in caso di errore di rete/5xx
# WEBHOOK_CONFIG_FILE=     # percorso a webhook.json (sovrascrive le var sopra)
